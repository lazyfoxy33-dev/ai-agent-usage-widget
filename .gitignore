# Work records (本地工作记录，不入库)
.work-records/

# Brainstorm visual companion scratch
.superpowers/

# Python
__pycache__/
*.pyc

# Local cache produced by the widget
.cache/

# Local credentials, sessions, and environment files
.env
.env.*
*.key
*.pem
*.p12
*.jsonl
!core/tests/fixtures/*.jsonl

# macOS
.DS_Store

# Touch Bar build artifacts (compiled bundle, iCloud dupes, distribution dmg)
touchbar/QuotaBar*.app/
touchbar/build/

# Native macOS widget build and local Xcode state
macwidget/build/
macwidget/DerivedData/
macwidget/**/*.xcuserstate
macwidget/**/xcuserdata/

# Tauri/Rust build output and generated local schemas
windows-widget/src-tauri/target/
windows-widget/src-tauri/gen/

# Runtime usage snapshots
usage.json
*.usage.json
