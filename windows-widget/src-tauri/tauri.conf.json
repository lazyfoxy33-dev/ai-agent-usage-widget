{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Agent Usage Widget",
  "version": "0.1.0",
  "identifier": "dev.lazyfoxy.ai-agent-usage-widget",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "AI Agent Usage",
        "width": 320,
        "height": 500,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "resources": {
      "../../core": "core"
    }
  }
}
